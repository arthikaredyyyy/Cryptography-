from Crypto.Cipher import DES3
from Crypto.Random import get_random_bytes
from Crypto.Util.Padding import pad, unpad

data = b"SecretMessage123"
key = DES3.adjust_key_parity(get_random_bytes(24))
iv = get_random_bytes(8)

cipher_ecb = DES3.new(key, DES3.MODE_ECB)
encrypted_ecb = cipher_ecb.encrypt(pad(data, DES3.block_size))
decipher_ecb = DES3.new(key, DES3.MODE_ECB)
decrypted_ecb = unpad(decipher_ecb.decrypt(encrypted_ecb), DES3.block_size)

cipher_cbc = DES3.new(key, DES3.MODE_CBC, iv)
encrypted_cbc = cipher_cbc.encrypt(pad(data, DES3.block_size))
decipher_cbc = DES3.new(key, DES3.MODE_CBC, iv)
decrypted_cbc = unpad(decipher_cbc.decrypt(encrypted_cbc), DES3.block_size)

cipher_cfb = DES3.new(key, DES3.MODE_CFB, iv, segment_size=64)
encrypted_cfb = cipher_cfb.encrypt(data)
decipher_cfb = DES3.new(key, DES3.MODE_CFB, iv, segment_size=64)
decrypted_cfb = decipher_cfb.decrypt(encrypted_cfb)

print(encrypted_ecb, decrypted_ecb)
print(encrypted_cbc, decrypted_cbc)
print(encrypted_cfb, decrypted_cfb)
