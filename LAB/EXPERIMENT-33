from Crypto.Cipher import DES
from Crypto.Random import get_random_bytes
from Crypto.Util.Padding import pad, unpad

key = get_random_bytes(8)  # DES key is 64 bits (56 bits used, 8 parity bits)
data = b"SecretMsg12345"   # 64-bit blocks, padded automatically

cipher = DES.new(key, DES.MODE_ECB)
encrypted = cipher.encrypt(pad(data, DES.block_size))

decipher = DES.new(key, DES.MODE_ECB)
decrypted = unpad(decipher.decrypt(encrypted), DES.block_size)

print("Key:", key.hex())
print("Plaintext:", data)
print("Ciphertext:", encrypted.hex())
print("Decrypted:", decrypted)
