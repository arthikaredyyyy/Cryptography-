BLOCK_SIZE = 12

def xor_block(a, b):
    return ''.join('0' if a[i]==b[i] else '1' for i in range(BLOCK_SIZE))

def sdes_encrypt_block(plain, key):
    return ''.join('0' if plain[i]==key[i] else '1' for i in range(BLOCK_SIZE))

def sdes_decrypt_block(cipher, key):
    return ''.join('0' if cipher[i]==key[i] else '1' for i in range(BLOCK_SIZE))

def encrypt_cbc(plaintext_blocks, key, iv):
    ciphertext_blocks = []
    prev = iv
    for block in plaintext_blocks:
        temp = xor_block(block, prev)
        cipher = sdes_encrypt_block(temp, key)
        ciphertext_blocks.append(cipher)
        prev = cipher
    return ciphertext_blocks

def decrypt_cbc(ciphertext_blocks, key, iv):
    plaintext_blocks = []
    prev = iv
    for block in ciphertext_blocks:
        temp = sdes_decrypt_block(block, key)
        plain = xor_block(temp, prev)
        plaintext_blocks.append(plain)
        prev = block
    return plaintext_blocks

key = "011111110101"
iv = "101010101010"
plaintext_blocks = ["000000010010"]

ciphertext_blocks = encrypt_cbc(plaintext_blocks, key, iv)
decrypted_blocks = decrypt_cbc(ciphertext_blocks, key, iv)

print("Plaintext:", plaintext_blocks[0])
print("Ciphertext:", ciphertext_blocks[0])
print("Decrypted:", decrypted_blocks[0])
