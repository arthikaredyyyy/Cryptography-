import math
total_keys = math.factorial(25)
power_total = math.log2(total_keys)

unique_keys = total_keys // (2 * (math.factorial(5) ** 2))
power_unique = math.log2(unique_keys)

print("Total possible keys (25!) =", total_keys)
print("Approximate power of 2 =", round(power_total))

print("\nEffectively unique keys =", unique_keys)
print("Approximate power of 2 =", round(power_unique))
