import numpy as np

mod = 26

def mod_inv(a):
    for i in range(1, mod):
        if (a*i) % mod == 1:
            return i
    return None

def matrix_mod_inv(matrix):
    det = int(round(np.linalg.det(matrix))) % mod
    det_inv = mod_inv(det)
    adj = np.round(det * np.linalg.inv(matrix)).astype(int) % mod
    return (det_inv * adj) % mod

def text_to_numbers(text):
    return [ord(c)-65 for c in text.upper()]

def numbers_to_text(nums):
    return ''.join(chr(n%26+65) for n in nums)

def recover_key(plain, cipher, n):
    p = text_to_numbers(plain)
    c = text_to_numbers(cipher)

    P = np.array(p).reshape(n,n)
    C = np.array(c).reshape(n,n)

    P_inv = matrix_mod_inv(P)
    K = np.dot(P_inv, C) % mod
    return K

def encrypt(plain, key):
    p = text_to_numbers(plain)
    n = key.shape[0]
    res = []
    for i in range(0,len(p),n):
        block = np.array(p[i:i+n])
        enc = np.dot(block, key) % mod
        res.extend(enc)
    return numbers_to_text(res)

n = 2
plaintext = input("Enter known plaintext: ").upper()
ciphertext = input("Enter corresponding ciphertext: ").upper()

key = recover_key(plaintext[:n*n], ciphertext[:n*n], n)

print("Recovered Key Matrix:")
print(key)

test = input("Enter plaintext to encrypt: ").upper()
print("Encrypted:", encrypt(test, key))
