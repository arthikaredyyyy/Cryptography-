from Crypto.PublicKey import RSA
from Crypto.Signature import DSS
from Crypto.Hash import SHA256
from Crypto.Random import get_random_bytes
message = b"Test message"


rsa_key = RSA.generate(2048)
h = SHA256.new(message)
rsa_signature1 = rsa_key.sign(h, '')
rsa_signature2 = rsa_key.sign(h, '')

print("RSA Signature 1:", rsa_signature1)
print("RSA Signature 2:", rsa_signature2)
print("RSA signatures equal:", rsa_signature1 == rsa_signature2)

from Crypto.PublicKey import DSA
dsa_key = DSA.generate(1024)
h = SHA256.new(message)
signer = DSS.new(dsa_key, 'fips-186-3')
signature1 = signer.sign(h)
signature2 = signer.sign(h)

print("DSA Signature 1:", signature1.hex())
print("DSA Signature 2:", signature2.hex())
print("DSA signatures equal:", signature1 == signature2)
