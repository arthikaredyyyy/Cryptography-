text = input("Enter the message: ")
k = int(input("Enter shift value (1-25): "))

result = ""

for ch in text:
    if ch.isalpha():
        if ch.isupper():
            result += chr((ord(ch) - 65 + k) % 26 + 65)
        else:
            result += chr((ord(ch) - 97 + k) % 26 + 97)
    else:
        result += ch

print("Encrypted message:", result)
