import random

r = 1024
c = 576
lane_size = 64
num_lanes = 25
capacity_lanes = c // lane_size
state = [0]*num_lanes
for i in range(r//lane_size):
    state[i] = 1
for i in range(r//lane_size, num_lanes):
    state[i] = 0
steps = 0
while 0 in state[r//lane_size:]:
    steps += 1
    for i in range(r//lane_size, num_lanes):
        if random.choice([True, False]):
            state[i] = 1
print(steps)
