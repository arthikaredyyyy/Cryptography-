import string

def gcd(a,b):
    while b:
        a,b = b, a%b
    return a

def modinv(a,m):
    for i in range(1,m):
        if (a*i)%m == 1:
            return i
    return None

def affine_encrypt(text,a,b):
    text = text.upper()
    cipher = ""
    for char in text:
        if char in string.ascii_uppercase:
            p = ord(char)-65
            c = (a*p + b)%26
            cipher += chr(c+65)
        else:
            cipher += char
    return cipher

def affine_decrypt(cipher,a,b):
    a_inv = modinv(a,26)
    if a_inv is None:
        raise ValueError("a has no modular inverse mod 26, decryption impossible")
    text = ""
    for char in cipher:
        if char in string.ascii_uppercase:
            c = ord(char)-65
            p = (a_inv*(c - b))%26
            text += chr(p+65)
        else:
            text += char
    return text

message = "HELLO WORLD"
a,b = 5,8
if gcd(a,26)!=1:
    raise ValueError("a must be coprime with 26 for one-to-one mapping")

cipher = affine_encrypt(message,a,b)
plain = affine_decrypt(cipher,a,b)

print("Plaintext:", message)
print("Ciphertext:", cipher)
print("Decrypted:", plain)
