ciphertext = input("Enter ciphertext: ").upper()

a = 17
b = 11

plaintext = ""

# find modular inverse of a
for i in range(26):
    if (a * i) % 26 == 1:
        a_inv = i
        break

for ch in ciphertext:
    if ch.isalpha():
        c = ord(ch) - ord('A')
        p = (a_inv * (c - b)) % 26
        plaintext += chr(p + ord('A'))
    else:
        plaintext += ch

print("Decrypted text:", plaintext)
